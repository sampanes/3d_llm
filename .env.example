# LLM API Keys — copy this to .env and fill in the keys you have.
# Only needed for the API pipeline (scripts/generate.py). The agent-driven
# workflow (AGENTS.md) and all mesh tools work with no keys at all.
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-key-here

# Local models (no key needed; just have Ollama running)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenSCAD path — auto-detected; the project-local portable install at
# tools\openscad\openscad.com is found first. Override only if needed.
# OPENSCAD_PATH=C:\Program Files\OpenSCAD\openscad.exe

# Default settings for scripts/generate.py (per-invocation flags override these).
# Current model IDs as of 2026-06.
DEFAULT_LLM=anthropic        # openai, anthropic, google, ollama
DEFAULT_MODEL=claude-opus-4-8
DEFAULT_PIPELINE=openscad    # openscad, cadquery, sdf
